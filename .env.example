# ── GitHub JSON storage (shared) ───────────────────────────────────────────
# A PUBLIC GitHub repo holds your data file. The dashboard reads it without a
# token; you write to it by pasting a Personal Access Token at /admin.
# These values are NOT secret.
VITE_GH_OWNER=your-github-username
VITE_GH_REPO=ftrack
VITE_GH_BRANCH=main
VITE_GH_PATH=data.json

# ── Fallback (optional) ────────────────────────────────────────────────────
# Used ONLY when the GitHub values above are empty (local dev without GitHub).
# Data then lives in this browser's localStorage and is not shared.
VITE_ADMIN_PASSWORD=changeme
